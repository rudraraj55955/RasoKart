modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "settings-persistence"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test:settings-persistence"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-merchant-settings-persistence"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "verify-priority-conflict-tests"

[[workflows.workflow]]
name = "settings-persistence"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run verify-settings-persistence"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test:settings-persistence"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/scripts && psql \"$DATABASE_URL\" -c \"DELETE FROM rate_limit_hits;\" && PLAYWRIGHT_BROWSERS_PATH=/home/runner/workspace/.cache/ms-playwright pnpm exec playwright test --config=playwright.config.ts e2e/settings-persistence.spec.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test-merchant-settings-persistence"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/scripts && psql \"$DATABASE_URL\" -c \"DELETE FROM rate_limit_hits;\" && PLAYWRIGHT_BROWSERS_PATH=/home/runner/workspace/.cache/ms-playwright pnpm exec playwright test --config=playwright.config.ts e2e/merchant-settings-persistence.spec.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "verify-priority-conflict-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run verify-priority-conflict-tests"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 5000

[[ports]]
localPort = 24827
externalPort = 3000

[nix]
channel = "stable-25_05"

[objectStorage]
defaultBucketID = "replit-objstore-5efacb58-05f3-42e2-b1e3-ffef14766903"

[userenv]

[userenv.shared]
GITHUB_REPO = "rudraraj55955/RasoKart"
