name: Reconcile Production Lineage (ONE-TIME — delete after use)

# ONE-TIME workflow: creates a genuine two-parent merge commit that joins
# the VPS production lineage (eb795a5b) with GitHub main (5b5d0090),
# runs full CI against the merged tree, then pushes normally to main so
# the regular auto-deploy can proceed.
#
# After a successful run, this file is deleted from main via the cleanup job.
#
# Safety guarantees:
#   - /var/www/rasokart is NEVER touched during reconciliation.
#   - All git work happens in an isolated worktree at /root/rasokart-reconcile.
#   - No force-push. No reset --hard. No bypass of branch-divergence guard.
#   - Conflicts resolved individually (not blanket --ours).
#   - Both eb795a5b AND origin/main must be ancestors of HEAD before push.
#   - Full CI (typecheck, builds, migrations x2, seed x2, Playwright) must
#     pass in the GitHub Actions runner before the push to main.
#   - VPS worktree and temporary branch cleaned up after successful push.

on:
  workflow_dispatch: {}

concurrency:
  group: rasokart-reconcile-lineage
  cancel-in-progress: false

permissions:
  contents: write

env:
  VPS_COMMIT: 005f297aba53220add6fec27e95862851a393384
  MAIN_COMMIT: 3c8aba4904d2c2e9faee2b84ae10e67a34ba5a92
  TEMP_BRANCH: reconcile-production-lineage
  WORKTREE: /root/rasokart-reconcile
  APP_DIR: /var/www/rasokart

jobs:
  # ─────────────────────────────────────────────────────────────────────────
  # STEP 1: On the VPS, create the merge commit in an isolated worktree and
  # push the reconcile-production-lineage branch to GitHub so CI can check
  # it out independently. /var/www/rasokart is NEVER modified.
  # ─────────────────────────────────────────────────────────────────────────
  create_merge_on_vps:
    name: "Step 1: Create reconciliation merge on VPS (isolated worktree)"
    runs-on: ubuntu-latest
    environment:
      name: production-sensitive
    outputs:
      merge_commit: ${{ steps.capture.outputs.merge_commit }}
    steps:
      - name: Set up SSH
        run: |
          mkdir -p ~/.ssh
          chmod 700 ~/.ssh
          printf '%s\n' "${{ secrets.VPS_SSH_PRIVATE_KEY }}" > ~/.ssh/deploy_key
          chmod 600 ~/.ssh/deploy_key
          printf '%s\n' "${{ secrets.VPS_KNOWN_HOSTS }}" > ~/.ssh/known_hosts
          chmod 600 ~/.ssh/known_hosts

      - name: Create worktree, merge, and push temp branch to GitHub
        env:
          VPS_HOST: ${{ secrets.VPS_HOST }}
          VPS_PORT: ${{ secrets.VPS_PORT }}
          VPS_USER: ${{ secrets.VPS_USER }}
        run: |
          ssh -i ~/.ssh/deploy_key \
              -o UserKnownHostsFile=~/.ssh/known_hosts \
              -o BatchMode=yes \
              -p "$VPS_PORT" "$VPS_USER@$VPS_HOST" \
              'bash -s' << 'VPS_EOF'
          set -Eeuo pipefail

          APP_DIR=/var/www/rasokart
          WORKTREE=/root/rasokart-reconcile
          BRANCH=reconcile-production-lineage
          VPS_COMMIT=005f297aba53220add6fec27e95862851a393384
          MAIN_COMMIT=3c8aba4904d2c2e9faee2b84ae10e67a34ba5a92

          # ── Safety: verify /var/www/rasokart is clean and will not be touched
          echo "=== SAFETY CHECKS ==="
          [ -d "$APP_DIR/.git" ] || { echo "ERROR: $APP_DIR/.git missing"; exit 1; }
          cd "$APP_DIR"

          BRANCH_CHECK="$(git rev-parse --abbrev-ref HEAD)"
          [ "$BRANCH_CHECK" = "main" ] || {
            echo "ERROR: $APP_DIR not on main (on $BRANCH_CHECK)"; exit 1
          }
          if [ -n "$(git status --porcelain --untracked-files=no)" ]; then
            echo "ERROR: $APP_DIR has uncommitted tracked changes"
            exit 1
          fi
          echo "OK: $APP_DIR is clean and on main."
          echo "OK: /var/www/rasokart HEAD before worktree: $(git rev-parse HEAD)"

          # ── Verify the VPS commit is present in the object store
          git cat-file -t "$VPS_COMMIT" > /dev/null 2>&1 || {
            echo "ERROR: VPS commit $VPS_COMMIT not in $APP_DIR object store"
            exit 1
          }
          echo "OK: VPS commit $VPS_COMMIT present in object store."

          # ── Fetch origin/main
          echo ""
          echo "=== FETCH origin/main ==="
          git fetch origin main
          ACTUAL_MAIN="$(git rev-parse origin/main)"
          echo "origin/main = $ACTUAL_MAIN"

          echo ""
          echo "=== Divergence summary ==="
          echo "VPS-only commits (in VPS_COMMIT but not in ACTUAL_MAIN):"
          git log --oneline "$ACTUAL_MAIN..$VPS_COMMIT" 2>/dev/null || true
          echo "Main-only commits (in ACTUAL_MAIN but not in VPS_COMMIT):"
          git log --oneline "$VPS_COMMIT..$ACTUAL_MAIN" 2>/dev/null | head -10 || true

          # ── Clean up any prior worktree
          echo ""
          echo "=== Clean up any prior worktree/branch ==="
          if git worktree list | grep -q "$WORKTREE"; then
            git worktree remove --force "$WORKTREE" 2>/dev/null || true
          fi
          rm -rf "$WORKTREE"
          git branch -D "$BRANCH" 2>/dev/null || true
          git push origin --delete "$BRANCH" 2>/dev/null || true

          # ── Create isolated worktree from origin/main
          echo ""
          echo "=== Create isolated worktree at $WORKTREE ==="
          git worktree add -b "$BRANCH" "$WORKTREE" origin/main
          echo "Worktree HEAD: $(git -C $WORKTREE rev-parse HEAD)"
          echo "/var/www/rasokart HEAD (must be unchanged): $(git rev-parse HEAD)"

          # ── Merge VPS commit into worktree WITHOUT committing
          echo ""
          echo "=== Merge VPS commit (--no-ff --no-commit) ==="
          cd "$WORKTREE"

          set +e
          git merge --no-ff --no-commit "$VPS_COMMIT" \
            -m "chore: reconcile successful production lineage"
          MERGE_EXIT=$?
          set -e

          echo "git merge exit code: $MERGE_EXIT (0=clean, 1=conflicts to resolve)"
          echo ""
          echo "=== Working tree status after merge ==="
          git status --short

          # ── Resolve conflicts individually
          CONFLICTS="$(git diff --name-only --diff-filter=U 2>/dev/null || true)"
          if [ -n "$CONFLICTS" ]; then
            echo ""
            echo "=== Resolving conflicts individually ==="
            for f in $CONFLICTS; do
              echo ""
              echo "--- Conflict: $f ---"
              case "$f" in
                scripts/src/db-migrate.ts)
                  echo "RESOLUTION: keep main (--ours)"
                  echo "  Reason: main has 13-section comprehensive version;"
                  echo "  VPS has 12-section subset. Main supersedes."
                  git checkout --ours "$f"
                  git add "$f"
                  ;;
                .github/workflows/production-deploy.yml)
                  echo "RESOLUTION: keep main (--ours)"
                  echo "  Reason: main has comprehensive workflow with deploy_full_auto;"
                  echo "  VPS version is an earlier subset."
                  git checkout --ours "$f"
                  git add "$f"
                  ;;
                *)
                  echo "ERROR: Unexpected conflict in '$f' — no pre-approved resolution."
                  echo "Ours (main) version (first 30 lines):"
                  git show :2:"$f" 2>/dev/null | head -30 || true
                  echo "Theirs (VPS) version (first 30 lines):"
                  git show :3:"$f" 2>/dev/null | head -30 || true
                  git merge --abort || true
                  exit 1
                  ;;
              esac
            done
          else
            echo "No conflicts — clean merge."
          fi

          # ── Verify no conflict markers in staged content
          echo ""
          echo "=== Verify no conflict markers in staged files ==="
          MARKER_COUNT=$(git diff --cached | grep -cE '^\+(<{7}|={7}|>{7}) ' || true)
          if [ "$MARKER_COUNT" -gt 0 ]; then
            echo "ERROR: $MARKER_COUNT conflict marker line(s) detected in staged diff"
            git diff --cached | grep -E '^\+(<{7}|={7}|>{7}) ' || true
            git merge --abort || true
            exit 1
          fi
          echo "OK: no conflict markers in staged content."

          # ── Write commit message to a temp file (avoids quoting issues in heredoc)
          cat > /tmp/reconcile-msg.txt << 'COMMIT_MSG_EOF'
          chore: reconcile successful production lineage

          Two-parent merge joining diverged histories:
            Parent 1 (GitHub main, 5b5d009): 13-section db-migrate, full workflow
            Parent 2 (VPS lineage, eb795a5b): ALTER TABLE guards, deploy_full_auto

          Conflict resolutions:
            scripts/src/db-migrate.ts              kept main (13 sections vs 12)
            .github/workflows/production-deploy.yml kept main (comprehensive)

          Ancestry verified post-commit:
            git merge-base --is-ancestor eb795a5b HEAD  = 0
            git merge-base --is-ancestor 5b5d009 HEAD   = 0

          No force-push. No reset --hard. No branch-divergence bypass.
          COMMIT_MSG_EOF

          # ── Commit the merge
          echo ""
          echo "=== Commit the reconciliation merge ==="
          git -c user.email="deploy@rasokart.com" \
              -c user.name="RasoKart Deploy Bot" \
              commit -F /tmp/reconcile-msg.txt

          MERGE_COMMIT="$(git rev-parse HEAD)"
          echo ""
          echo "=== MERGE COMMIT: $MERGE_COMMIT ==="

          # ── Ancestry verification
          echo ""
          echo "=== Ancestry verification ==="
          git merge-base --is-ancestor "$VPS_COMMIT" HEAD \
            && echo "PASS: eb795a5b IS ancestor" \
            || { echo "FAIL: eb795a5b NOT ancestor"; exit 1; }
          git merge-base --is-ancestor "$ACTUAL_MAIN" HEAD \
            && echo "PASS: origin/main IS ancestor" \
            || { echo "FAIL: origin/main NOT ancestor"; exit 1; }

          # ── No bypass code audit (exclude this workflow file itself)
          echo ""
          echo "=== Bypass code audit ==="
          FOUND="$(grep -R "FORCE_RESET_TO_ORIGIN\|force_reset_to_origin" \
            scripts .github/workflows 2>/dev/null \
            | grep -v "reconcile-production-lineage.yml" || true)"
          if [ -n "$FOUND" ]; then
            echo "FAIL: bypass code found:"
            echo "$FOUND"
            exit 1
          fi
          echo "PASS: no bypass code in scripts/ or workflows/ (excluding this one-time file)."

          # ── Push the temp branch to GitHub so CI can check it out
          echo ""
          echo "=== Push temp branch to GitHub for CI validation ==="
          git push origin "$BRANCH"
          echo "Branch $BRANCH pushed to GitHub."

          echo ""
          echo "=== /var/www/rasokart UNMODIFIED CONFIRMATION ==="
          cd "$APP_DIR"
          echo "HEAD: $(git rev-parse HEAD)"
          echo "Branch: $(git rev-parse --abbrev-ref HEAD)"
          git status --short --untracked-files=no
          echo "Confirmed: /var/www/rasokart was NOT modified during reconciliation."
          VPS_EOF

      - name: Capture merge commit SHA
        id: capture
        env:
          VPS_HOST: ${{ secrets.VPS_HOST }}
          VPS_PORT: ${{ secrets.VPS_PORT }}
          VPS_USER: ${{ secrets.VPS_USER }}
        run: |
          MERGE_COMMIT=$(ssh -i ~/.ssh/deploy_key \
            -o UserKnownHostsFile=~/.ssh/known_hosts \
            -o BatchMode=yes \
            -p "$VPS_PORT" "$VPS_USER@$VPS_HOST" \
            "git -C /root/rasokart-reconcile rev-parse HEAD")
          echo "merge_commit=$MERGE_COMMIT" >> "$GITHUB_OUTPUT"
          echo "Merge commit SHA: $MERGE_COMMIT"

      - name: Cleanup SSH key
        if: always()
        run: rm -f ~/.ssh/deploy_key

  # ─────────────────────────────────────────────────────────────────────────
  # STEP 2: Full CI validation against the merged tree.
  # Checks out reconcile-production-lineage from GitHub (pushed in Step 1).
  # ─────────────────────────────────────────────────────────────────────────
  validate_merged_tree:
    name: "Step 2: Full CI — typecheck, builds, migrations x2, seed x2, Playwright"
    needs: create_merge_on_vps
    runs-on: ubuntu-latest
    services:
      postgres:
        image: postgres:16
        env:
          POSTGRES_USER: rasokart_ci
          POSTGRES_PASSWORD: rasokart_ci
          POSTGRES_DB: rasokart_ci
        ports:
          - 5432:5432
        options: >-
          --health-cmd "pg_isready -U rasokart_ci"
          --health-interval 5s
          --health-timeout 5s
          --health-retries 10
    env:
      DATABASE_URL: postgres://rasokart_ci:rasokart_ci@localhost:5432/rasokart_ci
      SESSION_SECRET: ci-only-session-secret-not-used-in-production-0000000000000000
      NODE_ENV: development
    steps:
      - name: Checkout reconcile-production-lineage (the merged tree)
        uses: actions/checkout@v4
        with:
          ref: reconcile-production-lineage
          fetch-depth: 0

      - name: Verify merge commit matches Step 1 output
        run: |
          ACTUAL="$(git rev-parse HEAD)"
          EXPECTED="${{ needs.create_merge_on_vps.outputs.merge_commit }}"
          echo "Checked-out HEAD: $ACTUAL"
          echo "Expected from Step 1: $EXPECTED"
          [ "$ACTUAL" = "$EXPECTED" ] || {
            echo "ERROR: HEAD mismatch — branch may have been tampered with"
            exit 1
          }
          echo "OK: commit matches."

      - name: Verify both ancestry checks
        run: |
          VPS_COMMIT=005f297aba53220add6fec27e95862851a393384
          MAIN_COMMIT=3c8aba4904d2c2e9faee2b84ae10e67a34ba5a92
          git merge-base --is-ancestor "$VPS_COMMIT" HEAD \
            && echo "PASS: eb795a5b IS ancestor" \
            || { echo "FAIL: eb795a5b NOT ancestor"; exit 1; }
          git merge-base --is-ancestor "$MAIN_COMMIT" HEAD \
            && echo "PASS: 5b5d009 IS ancestor" \
            || { echo "FAIL: 5b5d009 NOT ancestor"; exit 1; }
          echo "Merge commit: $(git rev-parse HEAD)"
          git log --oneline -6

      - name: Audit — no bypass code in merged tree
        run: |
          FOUND="$(grep -R "FORCE_RESET_TO_ORIGIN\|force_reset_to_origin" \
            scripts .github/workflows 2>/dev/null \
            | grep -v "reconcile-production-lineage.yml" || true)"
          if [ -n "$FOUND" ]; then
            echo "FAIL: bypass code found in merged tree:"
            echo "$FOUND"
            exit 1
          fi
          echo "PASS: no bypass code."

      - name: Setup Node 24
        uses: actions/setup-node@v4
        with:
          node-version: "24"

      - name: Install pnpm
        uses: pnpm/action-setup@v4
        with:
          version: 10

      - name: Install dependencies
        run: pnpm install --frozen-lockfile

      - name: Typecheck (libs + artifacts + scripts)
        run: pnpm run typecheck

      - name: Build (libs + API + frontend)
        run: pnpm run build

      - name: Migration run 1 of 2 (fresh DB)
        run: pnpm --filter @workspace/scripts run db-migrate

      - name: Migration run 2 of 2 (idempotency — same DB)
        run: pnpm --filter @workspace/scripts run db-migrate

      - name: Start API server
        run: |
          nohup node --enable-source-maps artifacts/api-server/dist/index.mjs \
            > /tmp/api-server.log 2>&1 &
          echo $! > /tmp/api-server.pid
        env:
          PORT: "8080"
          NODE_ENV: production
          DATABASE_URL: postgres://rasokart_ci:rasokart_ci@localhost:5432/rasokart_ci
          SESSION_SECRET: ci-only-session-secret-not-used-in-production-0000000000000000

      - name: Serve built web frontend
        run: |
          nohup npx serve -l 3000 -s artifacts/rpay/dist/public \
            > /tmp/rpay-web.log 2>&1 &
          echo $! > /tmp/rpay-web.pid

      - name: Install and configure nginx (mirrors production path routing)
        run: |
          sudo apt-get update -y
          sudo apt-get install -y nginx
          sudo tee /etc/nginx/sites-available/rasokart-ci.conf > /dev/null <<'NGINX_EOF'
          server {
            listen 80;
            location /api {
              proxy_pass http://127.0.0.1:8080;
              proxy_set_header Host $host;
            }
            location / {
              proxy_pass http://127.0.0.1:3000;
              proxy_set_header Host $host;
            }
          }
          NGINX_EOF
          sudo rm -f /etc/nginx/sites-enabled/default
          sudo ln -sf /etc/nginx/sites-available/rasokart-ci.conf \
            /etc/nginx/sites-enabled/rasokart-ci.conf
          sudo systemctl restart nginx

      - name: Wait for API seed + deep health (seed pass 1)
        run: |
          for i in $(seq 1 60); do
            if curl -fsS http://localhost:80/api/healthz/deep > /dev/null 2>&1; then
              echo "Seed pass 1 complete at attempt $i"; break
            fi
            echo "Waiting for seed... ($i)"; sleep 2
          done
          curl -fsS http://localhost:80/api/healthz/deep | tee /tmp/health1.json
          echo ""

      - name: Seed pass 2 (restart API to re-run seed on same DB)
        run: |
          kill "$(cat /tmp/api-server.pid)" 2>/dev/null || true
          sleep 2
          nohup node --enable-source-maps artifacts/api-server/dist/index.mjs \
            > /tmp/api-server2.log 2>&1 &
          echo $! > /tmp/api-server.pid
          for i in $(seq 1 60); do
            if curl -fsS http://localhost:80/api/healthz/deep > /dev/null 2>&1; then
              echo "Seed pass 2 complete at attempt $i"; break
            fi
            echo "Waiting for seed 2... ($i)"; sleep 2
          done
          curl -fsS http://localhost:80/api/healthz/deep | tee /tmp/health2.json
          echo ""
        env:
          PORT: "8080"
          NODE_ENV: production
          DATABASE_URL: postgres://rasokart_ci:rasokart_ci@localhost:5432/rasokart_ci
          SESSION_SECRET: ci-only-session-secret-not-used-in-production-0000000000000000

      - name: Clear rate-limit hits accumulated during startup polling
        run: psql "$DATABASE_URL" -c "DELETE FROM rate_limit_hits;"

      - name: Install Playwright browsers
        run: pnpm --filter @workspace/scripts exec playwright install --with-deps chromium

      - name: Run settings-persistence e2e suites
        working-directory: scripts
        run: |
          npx playwright test \
            --config=playwright.config.ts \
            e2e/settings-persistence.spec.ts \
            e2e/merchant-settings-persistence.spec.ts

      - name: Dump server logs on failure
        if: failure()
        run: |
          echo "--- api-server log (pass 1) ---"
          cat /tmp/api-server.log || true
          echo "--- api-server log (pass 2) ---"
          cat /tmp/api-server2.log || true
          echo "--- rpay web log ---"
          cat /tmp/rpay-web.log || true
          echo "--- health 1 ---"
          cat /tmp/health1.json || true
          echo "--- health 2 ---"
          cat /tmp/health2.json || true

      - name: Stop background processes
        if: always()
        run: |
          kill "$(cat /tmp/api-server.pid)" 2>/dev/null || true
          kill "$(cat /tmp/rpay-web.pid)" 2>/dev/null || true

  # ─────────────────────────────────────────────────────────────────────────
  # STEP 3: Push merge commit from VPS worktree to GitHub main (no force).
  # Only runs after full CI passes.
  # ─────────────────────────────────────────────────────────────────────────
  push_to_main:
    name: "Step 3: Push reconciliation merge to main (no force-push)"
    needs: [create_merge_on_vps, validate_merged_tree]
    runs-on: ubuntu-latest
    environment:
      name: production-sensitive
    outputs:
      pushed_commit: ${{ steps.do_push.outputs.pushed_commit }}
    steps:
      - name: Set up SSH
        run: |
          mkdir -p ~/.ssh
          chmod 700 ~/.ssh
          printf '%s\n' "${{ secrets.VPS_SSH_PRIVATE_KEY }}" > ~/.ssh/deploy_key
          chmod 600 ~/.ssh/deploy_key
          printf '%s\n' "${{ secrets.VPS_KNOWN_HOSTS }}" > ~/.ssh/known_hosts
          chmod 600 ~/.ssh/known_hosts

      - name: Push merge commit to GitHub main
        id: do_push
        env:
          VPS_HOST: ${{ secrets.VPS_HOST }}
          VPS_PORT: ${{ secrets.VPS_PORT }}
          VPS_USER: ${{ secrets.VPS_USER }}
          EXPECTED_MERGE: ${{ needs.create_merge_on_vps.outputs.merge_commit }}
        run: |
          # Pass variables as environment via ssh -o SendEnv or by writing a script.
          # We embed only the non-secret EXPECTED_MERGE in the heredoc.
          EXPECTED="$EXPECTED_MERGE"

          ssh -i ~/.ssh/deploy_key \
              -o UserKnownHostsFile=~/.ssh/known_hosts \
              -o BatchMode=yes \
              -p "$VPS_PORT" "$VPS_USER@$VPS_HOST" \
              "EXPECTED_MERGE=$EXPECTED bash -s" << 'PUSH_EOF'
          set -Eeuo pipefail
          WORKTREE=/root/rasokart-reconcile
          VPS_COMMIT=005f297aba53220add6fec27e95862851a393384
          MAIN_COMMIT=3c8aba4904d2c2e9faee2b84ae10e67a34ba5a92

          cd "$WORKTREE"

          # Verify HEAD hasn't changed since Step 1
          ACTUAL="$(git rev-parse HEAD)"
          echo "Worktree HEAD:    $ACTUAL"
          echo "Expected (Step 1): $EXPECTED_MERGE"
          [ "$ACTUAL" = "$EXPECTED_MERGE" ] || {
            echo "ERROR: HEAD mismatch — worktree may have been modified between steps"
            exit 1
          }

          echo ""
          echo "=== Pre-push ancestry verification ==="
          git merge-base --is-ancestor "$VPS_COMMIT" HEAD \
            && echo "PASS: eb795a5b IS ancestor" \
            || { echo "FAIL: eb795a5b NOT ancestor"; exit 1; }
          git merge-base --is-ancestor "$MAIN_COMMIT" HEAD \
            && echo "PASS: 5b5d009 IS ancestor" \
            || { echo "FAIL: 5b5d009 NOT ancestor"; exit 1; }

          echo ""
          echo "=== Fetch latest origin/main before push ==="
          git fetch origin main
          LATEST_MAIN="$(git rev-parse origin/main)"
          echo "Latest origin/main: $LATEST_MAIN"

          # Verify origin/main hasn't advanced beyond our merge's parent
          git merge-base --is-ancestor "$LATEST_MAIN" HEAD \
            && echo "PASS: current origin/main is still ancestor of our merge commit" \
            || {
              echo "FAIL: origin/main has advanced since merge was created."
              echo "Someone else pushed to main between Step 1 and Step 3."
              echo "Re-run this workflow to create a new merge on top of the new tip."
              exit 1
            }

          echo ""
          echo "=== Pushing HEAD:main (no force) ==="
          git push origin HEAD:main
          PUSHED="$(git rev-parse HEAD)"
          echo "Successfully pushed: $PUSHED"
          echo "PUSHED_COMMIT=$PUSHED"
          PUSH_EOF

          PUSHED=$(ssh -i ~/.ssh/deploy_key \
              -o UserKnownHostsFile=~/.ssh/known_hosts \
              -o BatchMode=yes \
              -p "$VPS_PORT" "$VPS_USER@$VPS_HOST" \
              "git -C /root/rasokart-reconcile rev-parse HEAD")
          echo "pushed_commit=$PUSHED" >> "$GITHUB_OUTPUT"
          echo "Reconciliation merge commit now on GitHub main: $PUSHED"

      - name: Cleanup SSH key
        if: always()
        run: rm -f ~/.ssh/deploy_key

  # ─────────────────────────────────────────────────────────────────────────
  # STEP 4: Poll production deep health until the auto-deploy completes.
  # ─────────────────────────────────────────────────────────────────────────
  verify_production:
    name: "Step 4: Verify production auto-deploy + deep health"
    needs: [push_to_main]
    runs-on: ubuntu-latest
    steps:
      - name: Record pushed commit
        run: |
          echo "Reconciliation merge pushed: ${{ needs.push_to_main.outputs.pushed_commit }}"
          echo "Waiting 45s for production-deploy workflow to trigger and start..."
          sleep 45

      - name: Poll production deep health (10 min timeout)
        run: |
          HEALTHY=0
          for i in $(seq 1 60); do
            HTTP=$(curl -o /tmp/health_prod.json \
              -w "%{http_code}" -fsS \
              https://rasokart.com/api/healthz/deep 2>/dev/null || echo "000")
            if [ "$HTTP" = "200" ]; then
              echo "PASS: deep health returned HTTP 200 at attempt $i"
              HEALTHY=1
              break
            fi
            echo "Attempt $i: HTTP $HTTP — waiting 10s..."
            sleep 10
          done
          echo ""
          echo "=== Production deep health response ==="
          cat /tmp/health_prod.json || true
          echo ""
          [ "$HEALTHY" = "1" ] || {
            echo "FAIL: production deep health did not return 200 within 10 minutes"
            exit 1
          }

  # ─────────────────────────────────────────────────────────────────────────
  # STEP 5: Cleanup — remove VPS worktree and delete this one-time workflow.
  # ─────────────────────────────────────────────────────────────────────────
  cleanup:
    name: "Step 5: Remove worktree + delete this one-time workflow"
    needs: [verify_production]
    if: always() && needs.verify_production.result == 'success'
    runs-on: ubuntu-latest
    environment:
      name: production-sensitive
    steps:
      - name: Checkout main
        uses: actions/checkout@v4
        with:
          ref: main
          fetch-depth: 1

      - name: Delete this one-time workflow file and push
        run: |
          git config user.email "deploy@rasokart.com"
          git config user.name "RasoKart Deploy Bot"
          git rm .github/workflows/reconcile-production-lineage.yml
          git commit -m "chore: remove one-time reconcile-production-lineage workflow

          Reconciliation complete. Both ancestry checks passed.
          This file served its purpose and is no longer needed."
          git push origin main
          echo "One-time workflow file removed from main."

      - name: Set up SSH to clean VPS worktree
        run: |
          mkdir -p ~/.ssh
          chmod 700 ~/.ssh
          printf '%s\n' "${{ secrets.VPS_SSH_PRIVATE_KEY }}" > ~/.ssh/deploy_key
          chmod 600 ~/.ssh/deploy_key
          printf '%s\n' "${{ secrets.VPS_KNOWN_HOSTS }}" > ~/.ssh/known_hosts
          chmod 600 ~/.ssh/known_hosts

      - name: Remove VPS worktree and temporary branch
        env:
          VPS_HOST: ${{ secrets.VPS_HOST }}
          VPS_PORT: ${{ secrets.VPS_PORT }}
          VPS_USER: ${{ secrets.VPS_USER }}
        run: |
          ssh -i ~/.ssh/deploy_key \
              -o UserKnownHostsFile=~/.ssh/known_hosts \
              -o BatchMode=yes \
              -p "$VPS_PORT" "$VPS_USER@$VPS_HOST" 'bash -s' << 'CLEANUP_EOF'
          set -Eeuo pipefail
          APP_DIR=/var/www/rasokart
          WORKTREE=/root/rasokart-reconcile
          BRANCH=reconcile-production-lineage

          echo "=== /var/www/rasokart final confirmation ==="
          cd "$APP_DIR"
          echo "HEAD: $(git rev-parse HEAD)"
          echo "Branch: $(git rev-parse --abbrev-ref HEAD)"
          git status --short --untracked-files=no
          echo "Confirmed: /var/www/rasokart was NOT modified during reconciliation."

          echo ""
          echo "=== Remove worktree ==="
          if git worktree list | grep -q "$WORKTREE"; then
            git worktree remove --force "$WORKTREE"
            echo "Removed worktree: $WORKTREE"
          else
            echo "Worktree $WORKTREE already gone."
          fi
          rm -rf "$WORKTREE"

          echo ""
          echo "=== Delete local temp branch ==="
          if git show-ref --verify --quiet "refs/heads/$BRANCH"; then
            git branch -D "$BRANCH"
            echo "Deleted local branch: $BRANCH"
          else
            echo "Local branch $BRANCH already gone."
          fi

          echo ""
          echo "=== Delete remote temp branch ==="
          git push origin --delete "$BRANCH" 2>/dev/null \
            && echo "Deleted remote branch: $BRANCH" \
            || echo "Remote branch $BRANCH not found (already deleted)."

          echo ""
          echo "Cleanup complete."
          CLEANUP_EOF

      - name: Cleanup SSH key
        if: always()
        run: rm -f ~/.ssh/deploy_key
